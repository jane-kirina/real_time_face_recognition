APP_NAME=Real-Time Face Recognition
DEBUG=false
LOG_LEVEL=INFO

MODEL_NAME=buffalo_s
DET_SIZE=320
MATCH_THRESHOLD=0.5
DETECT_EVERY_N_FRAMES=5

TRACK_MAX_DISTANCE=80
TRACK_MAX_MISSED=10
SMOOTHING_WINDOW=5
LOG_COOLDOWN_SEC=5

FACE_DB_PATH=data/face_db.npy
EVENTS_LOG_PATH=data/events.jsonl

API_HOST=127.0.0.1
API_PORT=8000